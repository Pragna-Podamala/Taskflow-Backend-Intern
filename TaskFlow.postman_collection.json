{
  "info": {
    "name": "TaskFlow API",
    "description": "Complete API collection for TaskFlow — JWT Auth + RBAC + Task CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api/v1" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "task_id", "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success) {",
            "  pm.collectionVariables.set('access_token', res.data.accessToken);",
            "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
            "  pm.test('Status 201', () => pm.response.to.have.status(201));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin1234\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success) {",
            "  pm.collectionVariables.set('access_token', res.data.accessToken);",
            "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
            "  pm.test('Status 200', () => pm.response.to.have.status(200));",
            "  pm.test('Has access token', () => pm.expect(res.data.accessToken).to.be.a('string'));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success) {",
            "  pm.collectionVariables.set('access_token', res.data.accessToken);",
            "  pm.collectionVariables.set('refresh_token', res.data.refreshToken);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "✅ Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success) pm.collectionVariables.set('task_id', res.data._id);",
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Build REST API\",\n  \"description\": \"Design and implement a scalable REST API with JWT auth\",\n  \"status\": \"in-progress\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2025-06-30\",\n  \"tags\": [\"backend\", \"api\", \"nodejs\"]\n}"
            }
          }
        },
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/tasks?page=1&limit=10&status=in-progress",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "in-progress" }
              ]
            }
          }
        },
        {
          "name": "Get Tasks (with search)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/tasks?search=api&priority=high",
              "query": [
                { "key": "search", "value": "api" },
                { "key": "priority", "value": "high" }
              ]
            }
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/tasks/{{task_id}}"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/tasks/{{task_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\",\n  \"priority\": \"medium\"\n}"
            }
          }
        },
        {
          "name": "Get Task Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/tasks/stats"
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/tasks/{{task_id}}"
          }
        }
      ]
    },
    {
      "name": "🛡️ Admin (Admin token required)",
      "item": [
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/admin/dashboard"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/users?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/admin/users/USER_ID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/admin/users/USER_ID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/admin/users/USER_ID_HERE"
          }
        }
      ]
    },
    {
      "name": "🏥 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/health"
          }
        }
      ]
    }
  ]
}
